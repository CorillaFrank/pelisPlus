                <li><a href="/promociones"><i class="fas fa-tag"></i> Promociones</a></li>
                <li><a href="/about"><i class="fas fa-info-circle"></i> Acerca de</a></li>
                <li><a href="/loginCliente"><i class="fas fa-sign-in-alt"></i> Iniciar Sesión</a></li>
