                    <p>Explosiones, persecuciones y sequences épicas</p>
                </div>
            </div>
            <div class="movie-card">
                <img src="https://image.tmdb.org/t/p/w500/sJ4dkq3V1PtpmMnh85SYcQEg63W.jpg" alt="Parasite">
                <div class="movie-info">
                    <h3>Parasite</h3>
                    <p>Historias emocionales y profundas</p>
                </div>
            </div>
            <div class="movie-card">
                <img src="https://image.tmdb.org/t/p/w500/8zTZfp1Gc9PbV3kZzKhVFJLKKPe.jpg" alt="Grand Hotel Budapest">
                <div class="movie-info">
                    <h3>The Grand Budapest Hotel</h3>
                    <p>Risas garantizadas y humor divertido</p>
                </div>
            </div>
            <div class="movie-card">
                <img src="https://image.tmdb.org/t/p/w500/d5NXSklXo96JaJkd4iL1DLucP8C.jpg" alt="Dune">
                <div class="movie-info">
                    <h3>Dune</h3>
                    <p>Futuros distópicos y realidades alternativas</p>
                </div>
            </div>
            <div class="movie-card">
                <img src="https://image.tmdb.org/t/p/w500/rNB0ZV3jiLwJO3MrwAiJj8M6s4A.jpg" alt="Hereditary">
                <div class="movie-info">
                    <h3>Hereditary</h3>
                    <p>Aventuras aterradora y misteriosas</p>
                </div>
            </div>
            <div class="movie-card">
                <img src="https://image.tmdb.org/t/p/w500/ggJllcKk3Ymnpe3eFNHhQKjPfih.jpg" alt="Se7en">
                <div class="movie-info">
                    <h3>Se7en</h3>
                    <p>Historias llenas de intriga y giros</p>
                </div>
            </div>
        </div>
    </section>

    <footer>
        <div class="footer-links">
            <a href="/"><i class="fas fa-home"></i> Inicio</a>
            <a href="/about"><i class="fas fa-info-circle"></i> Acerca de</a>
            <a href="/"><i class="fas fa-envelope"></i> Contacto</a>
            <a href="/"><i class="fas fa-lock"></i> Privacidad</a>
        </div>
        <p>&copy; 2024 PelisPlus. Todos los derechos reservados.</p>
        <p>Desarrollado con <i class="fas fa-heart" style="color: #e50914;"></i> para los amantes del cine</p>
    </footer>

    <script>
        const menuToggle = document.querySelector('.menu-toggle');
        const menu = document.querySelector('nav ul');

        menuToggle.addEventListener('click', () => {
            menu.classList.toggle('show');
        });

        document.querySelectorAll('nav ul li a').forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.remove('show');
            });
        });

        // Control de sonido del video
        const heroVideo = document.getElementById('heroVideo');
        const soundToggle = document.getElementById('soundToggle');

        if (heroVideo && soundToggle) {
            soundToggle.addEventListener('click', (e) => {
                e.preventDefault();
                if (heroVideo.muted) {
                    heroVideo.muted = false;
                    soundToggle.innerHTML = '<i class="fas fa-volume-up"></i>';
                    soundToggle.title = 'Click para silenciar';
                } else {
                    heroVideo.muted = true;
                    soundToggle.innerHTML = '<i class="fas fa-volume-mute"></i>';
                    soundToggle.title = 'Click para activar sonido';
                }
            });
        }

        // Animación On Scroll
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.section').forEach(section => {
            observer.observe(section);
        });
    </script>
</body>
</html>